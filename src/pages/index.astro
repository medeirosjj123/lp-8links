---
import Layout from '../layouts/Layout.astro'
---

<Layout title="8links — Seu site na primeira página do Google no piloto automático">

<!-- ═══════════════════════════════════════════════════════════════════
     HEADER
     ═══════════════════════════════════════════════════════════════════ -->
<header class="fixed top-0 left-0 right-0 z-50 nav-glass">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="font-[family-name:var(--font-display)] font-800 text-xl text-text-primary">
      8links
    </a>
    <nav class="flex items-center gap-8">
      <a href="#como-funciona" class="text-text-secondary hover:text-text-primary transition-colors text-sm font-500">
        Como funciona
      </a>
      <a href="#resultados" class="text-text-secondary hover:text-text-primary transition-colors text-sm font-500">
        Resultados
      </a>
      <a href="#planos" class="text-text-secondary hover:text-text-primary transition-colors text-sm font-500">
        Planos
      </a>
      <a href="#faq" class="text-text-secondary hover:text-text-primary transition-colors text-sm font-500">
        FAQ
      </a>
    </nav>
    <a href="https://app.8links.com.br/login" target="_parent" rel="noopener" class="btn-glow inline-flex items-center gap-2 px-5 py-2.5 bg-orange-500 text-white font-[family-name:var(--font-display)] font-600 text-sm rounded-xl hover:bg-orange-400 transition-colors">
      Login
    </a>
  </div>
</header>

<!-- ═══════════════════════════════════════════════════════════════════
     SECTION 1: HERO
     ═══════════════════════════════════════════════════════════════════ -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
  <!-- Aurora background -->
  <div class="aurora"></div>
  <!-- Grid lines -->
  <div class="absolute inset-0 grid-lines opacity-40"></div>
  <!-- Radial fade from center -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_0%,var(--color-surface)_75%)]"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 pt-36 pb-24 text-center">
    <!-- Product badge -->
    <div class="reveal inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full border border-orange-500/20 bg-orange-500/[0.06] mb-10">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-orange-500"></span>
      </span>
      <span class="text-orange-400 text-xs font-600 font-[family-name:var(--font-mono)] tracking-widest uppercase">SEO Automático para seu site</span>
    </div>

    <!-- Headline -->
    <h1 class="reveal reveal-delay-1 font-[family-name:var(--font-display)] text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] font-800 leading-[0.92] tracking-tight mb-8">
      Seu site na<br>
      <span class="gradient-text">primeira página</span><br>
      do Google
    </h1>

    <!-- Subheadline -->
    <p class="reveal reveal-delay-2 text-text-secondary text-lg sm:text-xl md:text-2xl max-w-2xl mx-auto mb-3 leading-relaxed font-300">
      Sem criar conteúdo. Sem entender de SEO. Tudo automático.
    </p>
    <p class="reveal reveal-delay-2 text-text-muted text-base md:text-lg max-w-xl mx-auto mb-12">
      O 8links coloca seu site no topo do Google no piloto automático — enquanto você dorme, viaja ou faz qualquer outra coisa.
    </p>

    <!-- CTA group -->
    <div class="reveal reveal-delay-3 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="https://app.8links.com.br" target="_parent" rel="noopener" class="btn-glow inline-flex items-center gap-2.5 px-8 py-4 bg-orange-500 text-white font-[family-name:var(--font-display)] font-700 text-lg rounded-2xl hover:bg-orange-400 transition-colors">
        Começar agora
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="#planos" class="btn-outline inline-flex items-center gap-2 px-6 py-4 text-text-secondary font-500 text-base rounded-2xl">
        Ver planos
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
      </a>
    </div>
    <p class="reveal reveal-delay-3 text-text-muted text-sm mt-5">Comece grátis e veja seu site crescer no Google</p>

    <!-- Dashboard mockup -->
    <div class="reveal reveal-delay-4 mt-20 relative">
      <div class="absolute inset-0 bg-gradient-to-t from-surface via-transparent to-transparent z-10 pointer-events-none"></div>
      <div class="border-beam p-1">
        <div class="bg-surface-card rounded-[0.9rem] overflow-hidden">
          <img src="/images/dashboard.png" alt="Dashboard do 8links" class="w-full h-auto" />
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════
     SECTION 2: PROBLEMA
     ═══════════════════════════════════════════════════════════════════ -->
<section class="relative py-32 section-glow">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-20">
      <p class="reveal badge badge-orange mx-auto mb-5">O problema</p>
      <h2 class="reveal reveal-delay-1 font-[family-name:var(--font-display)] text-4xl sm:text-5xl md:text-6xl font-800 leading-tight tracking-tight">
        Você já tentou<br><span class="text-text-secondary">de tudo...</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      <div class="reveal card card-glow p-8 group">
        <div class="icon-box icon-box-md icon-box-red mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round"><path d="M12 8v4m0 4h.01"/><circle cx="12" cy="12" r="10"/></svg>
        </div>
        <h3 class="font-[family-name:var(--font-display)] text-xl font-700 mb-3">Publica todo dia...</h3>
        <p class="text-text-secondary leading-relaxed text-[15px]">Você escreve, publica, compartilha... e o Google simplesmente ignora seu site. As visitas não vêm. A frustração só cresce.</p>
      </div>

      <div class="reveal reveal-delay-1 card card-glow p-8 group">
        <div class="icon-box icon-box-md icon-box-red mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round"><path d="M2 12h5l3-9 4 18 3-9h5"/></svg>
        </div>
        <h3 class="font-[family-name:var(--font-display)] text-xl font-700 mb-3">Ferramentas caras e confusas</h3>
        <p class="text-text-secondary leading-relaxed text-[15px]">Ahrefs, Semrush... parecem painel de avião. Custam R$500+ por mês e só mostram dados — não fazem nada por você.</p>
      </div>

      <div class="reveal reveal-delay-2 card card-glow p-8 group">
        <div class="icon-box icon-box-md icon-box-red mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <h3 class="font-[family-name:var(--font-display)] text-xl font-700 mb-3">Agências cobram R$5.000/mês</h3>
        <p class="text-text-secondary leading-relaxed text-[15px]">E você nem sabe o que estão fazendo. Relatórios confusos, contratos longos, e resultados que nunca aparecem.</p>
      </div>
    </div>

    <p class="reveal text-center text-text-muted text-lg mt-14 max-w-2xl mx-auto leading-relaxed">
      Enquanto isso, seus concorrentes estão crescendo no Google. E você continua na página 5, falando sozinho.
    </p>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════
     SECTION 3: PONTE — EPIPHANY BRIDGE
     ═══════════════════════════════════════════════════════════════════ -->
<section class="relative py-32">
  <div class="orb orb-orange w-[500px] h-[500px] -left-[200px] top-1/2 -translate-y-1/2"></div>

  <div class="max-w-4xl mx-auto px-6 relative z-10">
    <div class="reveal card p-10 md:p-16 relative overflow-hidden">
      <div class="absolute -top-24 -right-24 w-64 h-64 bg-orange-500/8 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="relative z-10">
        <p class="badge badge-orange mb-8">A história</p>

        <div class="flex flex-col md:flex-row gap-10 items-start">
          <div class="shrink-0">
            <img src="/images/avatar.jpeg" alt="Bruno Medeiros" class="w-28 h-28 md:w-36 md:h-36 rounded-2xl border border-orange-500/15 object-cover" />
            <p class="text-center mt-3 text-sm text-text-secondary font-500">Bruno Medeiros</p>
            <p class="text-center text-xs text-text-muted">Fundador do 8links</p>
          </div>

          <div class="space-y-5 text-text-secondary text-[17px] leading-relaxed">
            <p>
              <span class="text-text-primary font-600">"Eu gastei anos fazendo SEO manual."</span> Construindo backlink um por um. Entrando em contato com site por site. Escrevendo artigo por artigo. Era um trabalho absurdo.
            </p>
            <p>
              Vi que meus clientes passavam pela mesma coisa. Pagavam caro, não entendiam nada, e desistiam em 3 meses. O SEO parecia um clube exclusivo pra quem já sabia tudo.
            </p>
            <p>
              Aí pensei: <span class="text-orange-400 font-600">e se uma ferramenta fizesse tudo isso por mim?</span> Se eu pudesse apertar um botão e o SEO simplesmente... acontecesse?
            </p>
            <p class="text-text-primary font-600">
              Foi assim que nasceu o 8links.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════
     SECTION 4: SOLUCAO — 3 STEPS
     ═══════════════════════════════════════════════════════════════════ -->
<section class="relative py-32 section-glow" id="como-funciona">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-20">
      <p class="reveal badge badge-orange mx-auto mb-5">A solução</p>
      <h2 class="reveal reveal-delay-1 font-[family-name:var(--font-display)] text-4xl sm:text-5xl md:text-6xl font-800 leading-tight tracking-tight">
        Simples assim.<br><span class="gradient-text">3 passos.</span>
      </h2>
      <p class="reveal reveal-delay-2 text-text-secondary text-lg mt-5 max-w-xl mx-auto">
        O 8links coloca seu site no Google no piloto automático. Sem complicação, sem conhecimento técnico.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <!-- Step 1 -->
      <div class="reveal text-center group">
        <div class="relative mx-auto mb-8">
          <div class="icon-box icon-box-lg icon-box-orange mx-auto group-hover:scale-110 transition-transform">
            <span class="font-[family-name:var(--font-display)] text-2xl font-800 text-orange-500">1</span>
          </div>
          <!-- Connector line (hidden on last) -->
          <div class="hidden md:block absolute top-1/2 left-[calc(50%+2.5rem)] w-[calc(100%-5rem)] h-px bg-gradient-to-r from-orange-500/20 to-transparent"></div>
        </div>
        <h3 class="font-[family-name:var(--font-display)] text-2xl font-700 mb-3">Cadastre seu site</h3>
        <p class="text-text-secondary text-[15px] leading-relaxed">Cole a URL do seu site. O 8links analisa tudo automaticamente: nicho, páginas, conteúdo.</p>
      </div>

      <!-- Step 2 -->
      <div class="reveal reveal-delay-1 text-center group">
        <div class="relative mx-auto mb-8">
          <div class="icon-box icon-box-lg icon-box-orange mx-auto group-hover:scale-110 transition-transform">
            <span class="font-[family-name:var(--font-display)] text-2xl font-800 text-orange-500">2</span>
          </div>
          <div class="hidden md:block absolute top-1/2 left-[calc(50%+2.5rem)] w-[calc(100%-5rem)] h-px bg-gradient-to-r from-orange-500/20 to-transparent"></div>
        </div>
        <h3 class="font-[family-name:var(--font-display)] text-2xl font-700 mb-3">Conecte o Google</h3>
        <p class="text-text-secondary text-[15px] leading-relaxed">Um clique. O 8links acessa seus dados do Google e descobre todas as oportunidades.</p>
      </div>

      <!-- Step 3 -->
      <div class="reveal reveal-delay-2 text-center group">
        <div class="relative mx-auto mb-8">
          <div class="w-[4.5rem] h-[4.5rem] mx-auto rounded-[0.875rem] bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center shadow-lg shadow-orange-500/25 group-hover:scale-110 group-hover:shadow-xl group-hover:shadow-orange-500/30 transition-all">
            <span class="font-[family-name:var(--font-display)] text-2xl font-800 text-white">3</span>
          </div>
        </div>
        <h3 class="font-[family-name:var(--font-display)] text-2xl font-700 mb-3">O 8links faz o resto</h3>
        <p class="text-text-secondary text-[15px] leading-relaxed">Backlinks, artigos, monitoramento — tudo no automático. Você só acompanha os resultados.</p>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════
     SECTION 5: COMO FUNCIONA — THE ENGINE
     ═══════════════════════════════════════════════════════════════════ -->
<section class="relative py-32">
  <div class="orb orb-amber w-[400px] h-[400px] right-[-150px] top-[20%]"></div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="text-center mb-20">
      <p class="reveal badge badge-orange mx-auto mb-5">Como funciona</p>
      <h2 class="reveal reveal-delay-1 font-[family-name:var(--font-display)] text-4xl sm:text-5xl md:text-6xl font-800 leading-tight tracking-tight">
        O motor por trás<br><span class="text-text-secondary">do seu crescimento</span>
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      <div class="reveal card card-glow p-8 group">
        <div class="flex items-start gap-5">
          <div class="icon-box icon-box-sm icon-box-orange">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="hsl(24,100%,55%)" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M11 8v6"/><path d="M8 11h6"/></svg>
          </div>
          <div>
            <h3 class="font-[family-name:var(--font-display)] text-xl font-700 mb-2">Detecta oportunidades</h3>
            <p class="text-text-secondary leading-relaxed text-[15px]">Encontra as palavras-chave que estão quase na primeira página. São essas que precisam de um empurrão — e o 8links dá.</p>
          </div>
        </div>
      </div>

      <div class="reveal reveal-delay-1 card card-glow p-8 group">
        <div class="flex items-start gap-5">
          <div class="icon-box icon-box-sm icon-box-orange">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="hsl(24,100%,55%)" stroke-width="1.5" stroke-linecap="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          </div>
          <div>
            <h3 class="font-[family-name:var(--font-display)] text-xl font-700 mb-2">Publica em 68+ sites reais</h3>
            <p class="text-text-secondary leading-relaxed text-[15px]">Artigos escritos por IA, publicados em sites brasileiros reais do mesmo nicho que o seu. Google vê como recomendação genuína.</p>
          </div>
        </div>
      </div>

      <div class="reveal reveal-delay-2 card card-glow p-8 group">
        <div class="flex items-start gap-5">
          <div class="icon-box icon-box-sm icon-box-orange">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="hsl(24,100%,55%)" stroke-width="1.5" stroke-linecap="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
          </div>
          <div>
            <h3 class="font-[family-name:var(--font-display)] text-xl font-700 mb-2">Monitora em tempo real</h3>
            <p class="text-text-secondary leading-relaxed text-[15px]">Acompanha cada palavra-chave, cada posição, cada clique. Você vê tudo subindo no dashboard — em tempo real.</p>
          </div>
        </div>
      </div>

      <div class="reveal reveal-delay-3 card card-glow p-8 group">
        <div class="flex items-start gap-5">
          <div class="icon-box icon-box-sm icon-box-orange">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="hsl(24,100%,55%)" stroke-width="1.5" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/><path d="M12 7v5l3 3"/></svg>
          </div>
          <div>
            <h3 class="font-[family-name:var(--font-display)] text-xl font-700 mb-2">Repete toda semana</h3>
            <p class="text-text-secondary leading-relaxed text-[15px]">Sem pausar, sem esquecer. O 8links trabalha toda semana, criando novos backlinks e fortalecendo seu site automaticamente.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════
     SECTION 6: RESULTADOS
     ═══════════════════════════════════════════════════════════════════ -->
<section class="relative py-32 section-glow" id="resultados">
  <div class="orb orb-orange w-[700px] h-[400px] left-1/2 -translate-x-1/2 top-1/2 -translate-y-1/2"></div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="text-center mb-20">
      <p class="reveal badge badge-orange mx-auto mb-5">Resultados</p>
      <h2 class="reveal reveal-delay-1 font-[family-name:var(--font-display)] text-4xl sm:text-5xl md:text-6xl font-800 leading-tight tracking-tight">
        Mais visitas.<br><span class="gradient-text">Mais dinheiro.</span>
      </h2>
    </div>

    <!-- Number tickers -->
    <div class="reveal grid grid-cols-2 md:grid-cols-4 gap-4 mb-20">
      <div class="stat-card">
        <div class="ticker text-3xl md:text-4xl font-700 text-orange-500 mb-2" data-target="12847" data-prefix="+">0</div>
        <p class="text-text-muted text-sm">visitas orgânicas</p>
      </div>
      <div class="stat-card">
        <div class="ticker text-3xl md:text-4xl font-700 text-orange-500 mb-2" data-target="4230" data-prefix="R$">0</div>
        <p class="text-text-muted text-sm">economia em ads</p>
      </div>
      <div class="stat-card">
        <div class="ticker text-3xl md:text-4xl font-700 text-orange-500 mb-2" data-target="68" data-suffix="+">0</div>
        <p class="text-text-muted text-sm">sites na rede</p>
      </div>
      <div class="stat-card">
        <div class="ticker text-3xl md:text-4xl font-700 text-orange-500 mb-2" data-target="347" data-suffix="%">0</div>
        <p class="text-text-muted text-sm">crescimento médio</p>
      </div>
    </div>

    <!-- Scenario cards -->
    <div class="grid md:grid-cols-3 gap-5">
      <div class="reveal card card-glow p-8 text-center">
        <div class="icon-box icon-box-md icon-box-green mx-auto mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <h3 class="font-[family-name:var(--font-display)] text-xl font-700 mb-3">Afiliados</h3>
        <p class="text-text-secondary text-[15px] leading-relaxed">5x mais visitas = 5x mais comissões. Seu site de afiliado vendendo no automático, sem gastar com ads.</p>
      </div>
      <div class="reveal reveal-delay-1 card card-glow p-8 text-center">
        <div class="icon-box icon-box-md icon-box-green mx-auto mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
        </div>
        <h3 class="font-[family-name:var(--font-display)] text-xl font-700 mb-3">AdSense & Ads</h3>
        <p class="text-text-secondary text-[15px] leading-relaxed">Mais tráfego = mais receita com anúncios. Seu blog gerando dinheiro enquanto você viaja.</p>
      </div>
      <div class="reveal reveal-delay-2 card card-glow p-8 text-center">
        <div class="icon-box icon-box-md icon-box-green mx-auto mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 class="font-[family-name:var(--font-display)] text-xl font-700 mb-3">Revendedores</h3>
        <p class="text-text-secondary text-[15px] leading-relaxed">Clientes vendo resultado = zero cancelamento. Revenda SEO sem precisar fazer o trabalho braçal.</p>
      </div>
    </div>

    <!-- Revenda -->
    <div class="reveal mt-20 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Texto -->
      <div>
        <div class="badge badge-orange mb-5">
